###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_to_a_secure_32_char_secret
###< symfony/framework-bundle ###

###> Database (AWS RDS Aurora PostgreSQL) ###
DATABASE_URL="postgresql://simplelms:${DB_PASSWORD}@${RDS_ENDPOINT}:5432/simplelms?serverVersion=16&charset=utf8"
###< Database ###

###> Cache / Sessions (AWS ElastiCache Redis) ###
REDIS_URL="redis://${ELASTICACHE_ENDPOINT}:6379"
###< Cache ###

###> Messenger (AWS SQS) ###
MESSENGER_TRANSPORT_DSN=sqs://sqs.eu-west-1.amazonaws.com/${AWS_ACCOUNT_ID}/simplelms-async?auto-setup=false
MESSENGER_TRANSPORT_FAILED_DSN=sqs://sqs.eu-west-1.amazonaws.com/${AWS_ACCOUNT_ID}/simplelms-failed?auto-setup=false
###< Messenger ###

###> JWT Auth ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
JWT_TTL=3600
###< JWT Auth ###

###> AI Provider ###
# Available providers: openai, ollama, claude, gemini, bedrock
AI_PROVIDER=ollama
###< AI Provider ###

###> AI Model ###
# Set to the model name for your chosen provider:
#   openai:  gpt-4o, gpt-4o-mini, o1-mini
#   claude:  claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
#   gemini:  gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-pro
#   bedrock: anthropic.claude-3-5-sonnet-20241022-v2:0, amazon.titan-text-premier-v1:0
#   ollama:  llama3, mistral, phi3
AI_MODEL=llama3
###< AI Model ###

###> OpenAI (used when AI_PROVIDER=openai) ###
OPENAI_API_KEY=sk-your-openai-api-key
###< OpenAI ###

###> Ollama (used when AI_PROVIDER=ollama) ###
OLLAMA_BASE_URL=http://localhost:11434/v1
###< Ollama ###

###> Anthropic Claude (used when AI_PROVIDER=claude) ###
# Note: Anthropic has no embeddings API — smart search requires openai, gemini, or bedrock
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
###< Anthropic Claude ###

###> Google Gemini (used when AI_PROVIDER=gemini) ###
GEMINI_API_KEY=your-gemini-api-key
###< Google Gemini ###

###> Embedding model ###
# openai / gemini: text-embedding-3-large, text-embedding-3-small
# bedrock:         amazon.titan-embed-text-v2:0
# ollama:          nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
###< Embedding model ###

###> AWS ###
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012
AWS_S3_BUCKET=simplelms-media
AWS_S3_BUCKET_TRANSCRIPTS=simplelms-transcripts
AWS_SES_FROM_EMAIL=noreply@simplelms.example.com
###< AWS ###

###> Mailer (AWS SES) ###
MAILER_DSN=ses+smtp://${AWS_SES_ACCESS_KEY}:${AWS_SES_SECRET_KEY}@default?region=eu-west-1
###< Mailer ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> Feature Flags ###
FEATURE_AI_TUTOR=true
FEATURE_SMART_SEARCH=true
FEATURE_PREDICTIVE_RETENTION=true
FEATURE_DOCUMENT_TO_COURSE=true
###< Feature Flags ###

###> AWS Transcribe / Bedrock ###
AWS_TRANSCRIBE_LANGUAGE=en-US
# Bedrock is available in us-east-1 and us-west-2; credentials use IAM role in ECS
AWS_BEDROCK_REGION=us-east-1
###< AWS Transcribe / Bedrock ###