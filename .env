###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_to_a_secure_32_char_secret
###< symfony/framework-bundle ###

###> Database (AWS RDS Aurora PostgreSQL) ###
DATABASE_URL="postgresql://talentlms:${DB_PASSWORD}@${RDS_ENDPOINT}:5432/talentlms?serverVersion=16&charset=utf8"
###< Database ###

###> Cache / Sessions (AWS ElastiCache Redis) ###
REDIS_URL="redis://${ELASTICACHE_ENDPOINT}:6379"
###< Cache ###

###> Messenger (AWS SQS) ###
MESSENGER_TRANSPORT_DSN=sqs://sqs.eu-west-1.amazonaws.com/${AWS_ACCOUNT_ID}/talentlms-async?auto-setup=false
MESSENGER_TRANSPORT_FAILED_DSN=sqs://sqs.eu-west-1.amazonaws.com/${AWS_ACCOUNT_ID}/talentlms-failed?auto-setup=false
###< Messenger ###

###> JWT Auth ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me
JWT_TTL=3600
###< JWT Auth ###

###> OpenAI ###
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
###< OpenAI ###

###> AWS ###
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012
AWS_S3_BUCKET=talentlms-media
AWS_S3_BUCKET_TRANSCRIPTS=talentlms-transcripts
AWS_SES_FROM_EMAIL=noreply@talentlms.example.com
###< AWS ###

###> Mailer (AWS SES) ###
MAILER_DSN=ses+smtp://${AWS_SES_ACCESS_KEY}:${AWS_SES_SECRET_KEY}@default?region=eu-west-1
###< Mailer ###

###> Feature Flags ###
FEATURE_AI_TUTOR=true
FEATURE_SMART_SEARCH=true
FEATURE_PREDICTIVE_RETENTION=true
FEATURE_DOCUMENT_TO_COURSE=true
###< Feature Flags ###

###> AWS Transcribe / Bedrock ###
AWS_TRANSCRIBE_LANGUAGE=en-US
AWS_BEDROCK_REGION=us-east-1
###< AWS Transcribe / Bedrock ###
